#!/bin/dash

vol="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

# If muted, print ¾░Øş and exit.
[ "$vol" != "${vol%\[MUTED\]}" ] && echo ¾░Øş && exit

vol="${vol#Volume: }"

split() {
	# For ommiting the . without calling and external program.
	IFS=$2
	set -- $1
	printf '%s' "$@"
}

vol="$(printf "%.0f" "$(split "$vol" ".")")"

case 1 in
	$((vol >= 70)) ) icon="´Ç¿" ;;
	$((vol >= 30)) ) icon="´Çğ" ;;
	$((vol >= 1)) ) icon="´ÇĞ" ;;
	* ) echo ´ÇĞ && exit ;;
esac

echo "$icon $vol%"
